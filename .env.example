# ============================================================
# SHOW UP — ENVIRONMENT VARIABLES
# Copy this to .env for local dev (never commit .env to git)
# Add ALL of these to Netlify → Site Settings → Environment Variables
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Service role key (NOT the anon key — this bypasses RLS)
SUPABASE_ANON_KEY=eyJ...           # Anon key (safe for frontend)

# ── STRIPE ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...      # sk_test_... for testing
STRIPE_PUBLISHABLE_KEY=pk_live_... # pk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...    # Get this from Stripe Dashboard → Webhooks

# Stripe Price IDs — create these in Stripe Dashboard
# Products → Add product → Add price (recurring)
STRIPE_PRICE_MONTHLY=price_...     # £15/month recurring
STRIPE_PRICE_ANNUAL=price_...      # £99/year recurring

# ── RESEND ────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@showupmedia.org
RESEND_FROM_NAME=Show Up

# ── APP ───────────────────────────────────────────────────
APP_URL=https://showupbooking.netlify.app  # Your Netlify URL
